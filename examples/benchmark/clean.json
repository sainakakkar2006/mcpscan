{
  "name": "recipe-box",
  "version": "2.0.1",
  "publisher": "example-labs",
  "transport": "https://mcp.example.com",
  "auth": { "type": "oauth2", "scopes": ["recipes:read"] },
  "tools": [
    {
      "name": "search_recipes",
      "description": "Search saved recipes by ingredient.",
      "inputSchema": {
        "type": "object",
        "properties": { "ingredient": { "type": "string" } }
      },
      "permissions": ["recipes:read"]
    }
  ]
}
